{
  "name": "akrobacja-top",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --port 8788",
    "deploy": "node scripts/deploy.mjs",
    "types": "wrangler types",
    "db:bootstrap:local": "wrangler d1 execute akrobacja-db --local --file=schema.sql",
    "db:bootstrap:remote": "wrangler d1 execute akrobacja-db --remote --file=schema.sql",
    "db:typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "aws4fetch": "^1.0.20",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@napi-rs/canvas": "^1.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.93.1"
  }
}
